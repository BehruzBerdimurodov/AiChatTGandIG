# .env — kalitlaringizni kiriting (GitHub ga YUKLAMANG!)

# Telegram bot tokeni — @BotFather dan oling
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Super admin Telegram ID — @userinfobot yoki @username_to_id_bot
SUPER_ADMIN_ID=123456789

# OpenAI API kaliti — platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model: gpt-4o-mini (arzon) yoki gpt-4o (kuchli)
OPENAI_MODEL=gpt-4o-mini

# Server porti
PORT=8000
