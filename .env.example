# .env — kalitlaringizni kiriting (GitHub ga YUKLAMANG!)

# Telegram bot tokeni — @BotFather dan oling
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Super admin Telegram ID — @userinfobot yoki @username_to_id_bot
SUPER_ADMIN_ID=123456789

# OpenAI API kaliti — platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model: gpt-4o-mini (arzon) yoki gpt-4o (kuchli)
OPENAI_MODEL=gpt-4o-mini

# Ichki API endpointlar uchun maxfiy token
INTERNAL_API_TOKEN=change-this-long-random-token

# Instagram webhook verify token
INSTAGRAM_VERIFY_TOKEN=change-this-instagram-verify-token

# Server porti
PORT=8000

# Railway/Telegram webhook rejimi
RUN_MODE=webhook
WEBHOOK_URL=https://your-railway-domain.up.railway.app
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_SECRET=change-this-telegram-webhook-secret

# Chatfuel JSON API webhook (Instagram DM)
# Chatfuel'da JSON API block URL: https://your-railway-domain.up.railway.app/webhook/chatfuel

# Buyurtmalar yuboriladigan guruh (ixtiyoriy)
# ORDERS_GROUP_ID=-1003786827758
